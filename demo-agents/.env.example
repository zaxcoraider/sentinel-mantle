# Deployer wallet — used by setup.ts to mint NFTs, deploy SafetyRules, register agents, fund guards.
# Must have at least 0.05 MNT on Mantle Sepolia.
DEPLOYER_PRIVATE_KEY=0x...

# Monitor wallet — used by manual-trigger.ts to fire circuit breakers.
# Must be the same wallet registered as the monitor in SentinelGuard.
MONITOR_PRIVATE_KEY=0x...

# Optional override; defaults to https://rpc.sepolia.mantle.xyz
MANTLE_SEPOLIA_RPC_URL=
